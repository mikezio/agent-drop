# Where Agent Drop stores shared files on the host.
AGENT_DROP_DIR=./data/agent-drop

# Web UI bind address and port.
AGENT_DROP_HOST=127.0.0.1
AGENT_DROP_PORT=8400

# Leave empty for http://localhost:8400/.
# Set to /drop only when serving behind a reverse proxy at that subpath.
NEXT_PUBLIC_BASE_PATH=

NEXT_TELEMETRY_DISABLED=1
